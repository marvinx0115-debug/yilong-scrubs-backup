---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services" description="OEM/ODM services for medical scrubs. Customizable labels, packaging, and logo options with flexible low MOQs starting from 10 sets.">
  <div class="container mx-auto px-4 py-24">
    <h1 class="text-5xl font-bold mb-8 text-center">Your Vision, Our Expertise</h1>
    <p class="text-slate-500 mb-20 text-center max-w-2xl mx-auto text-lg">Elevate your brand with Yilong’s comprehensive customization services and 20 years of manufacturing experience.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center mb-32">
      <div>
        <h2 class="text-4xl font-bold mb-8 italic text-primary">Flexible MOQ</h2>
        <p class="text-xl text-slate-700 mb-8 leading-relaxed">We support growing businesses with industry-leading low minimum order quantities. At Yilong Scrubs, we believe every successful brand starts somewhere.</p>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="bg-secondary/10 p-3 rounded-xl text-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-lg italic">10 - 50 Sets</h4>
              <p class="text-slate-500">Starting MOQ per style/color, perfect for new collection launches and niche brands.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-slate-100 h-64 rounded-3xl"></div>
        <div class="bg-slate-100 h-64 rounded-3xl translate-y-8"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="p-10 bg-slate-50 rounded-[2rem]">
        <h3 class="text-2xl font-bold mb-6 italic">Private Labeling</h3>
        <p class="text-slate-600 leading-relaxed">Custom neck labels, hangtags, and woven brand logos that reflect your unique brand identity.</p>
      </div>
      <div class="p-10 bg-slate-50 rounded-[2rem]">
        <h3 class="text-2xl font-bold mb-6 italic">Custom Packaging</h3>
        <p class="text-slate-600 leading-relaxed">Professional polybags or eco-friendly boxes tailored to your brand’s aesthetic and sustainability goals.</p>
      </div>
      <div class="p-10 bg-slate-50 rounded-[2rem]">
        <h3 class="text-2xl font-bold mb-6 italic">ODM Design Support</h3>
        <p class="text-slate-600 leading-relaxed">Our expert design team can help turn your sketches into high-performance medical apparel prototypes.</p>
      </div>
    </div>
  </div>
</Layout>
