---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Nursing Scrubs Collections" description="Explore Yilong Scrubs range of professional nursing scrub sets. High-quality model-featured uniforms for modern healthcare professionals.">
  <div class="container mx-auto px-4 py-24">
    <h1 class="text-5xl font-black mb-8 text-center italic text-slate-900">Nursing Scrub Collections</h1>
    <p class="text-slate-500 mb-20 text-center max-w-2xl mx-auto text-lg italic text-slate-600">Engineered for the modern healthcare professional. Combining ergonomic design with 20 years of manufacturing excellence.</p>
    
    <div class="space-y-32">
      <!-- Elite Series (Female Burgundy) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block px-4 py-1 bg-red-100 text-red-600 font-bold rounded-full text-xs mb-4 uppercase tracking-widest italic text-red-600">Elite Series</div>
          <h2 class="text-4xl font-black mb-6 italic text-slate-900 leading-tight">Premium V-Neck<br/>Burgundy Scrub Set</h2>
          <p class="text-xl text-slate-700 mb-8 leading-relaxed italic text-slate-600">The pinnacle of style and function. Featuring our most popular burgundy hue, this female-tailored set is designed for professionals who prioritize both performance and a modern silhouette.</p>
          
          <div class="bg-slate-50 p-6 rounded-2xl mb-8 border border-slate-100 shadow-sm">
            <h4 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-3 italic">Professional Fabric Specs</h4>
            <p class="text-lg font-bold text-red-600 italic">72% Polyester / 21% Rayon / 7% Spandex</p>
            <p class="text-sm text-slate-500 mt-2 italic">Weight: 205GSM | Style: Modern Tailored Fit | Features: 4-Way Stretch, Multi-Pocket Design</p>
          </div>
          
          <p class="font-bold text-slate-900 border-l-4 border-red-600 pl-4 italic italic text-red-900">Available in: Burgundy, Navy, Charcoal, and Hunter Green.</p>
        </div>
        <div class="aspect-[4/5] rounded-[3rem] overflow-hidden shadow-2xl relative">
          <img src="https://sc02.alicdn.com/kf/A5cf89e66f8724400a9dff9b9bac7cd03O.png" alt="Burgundy Scrub Set Female" class="w-full h-full object-cover" />
          <div class="absolute bottom-6 left-6 bg-white/90 backdrop-blur px-4 py-2 rounded-xl text-xs font-bold uppercase italic text-red-600 shadow-sm">Premium Burgundy</div>
        </div>
      </div>

      <!-- Versatile Series (Male Royal Blue) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 aspect-[4/5] rounded-[3rem] overflow-hidden shadow-2xl relative">
          <img src="https://sc02.alicdn.com/kf/A7e11502b0045464da109007ec18708f30.png" alt="Royal Blue Scrub Set Male" class="w-full h-full object-cover" />
          <div class="absolute bottom-6 right-6 bg-white/90 backdrop-blur px-4 py-2 rounded-xl text-xs font-bold uppercase italic text-blue-600 shadow-sm">Royal Blue Collection</div>
        </div>
        <div class="order-1 lg:order-2 text-right lg:text-left">
          <div class="inline-block px-4 py-1 bg-primary/10 text-primary font-bold rounded-full text-xs mb-4 uppercase tracking-widest italic text-primary">Versatile Series</div>
          <h2 class="text-4xl font-black mb-6 italic text-slate-900 leading-tight">Classic Royal Blue<br/>Modern Scrub Set</h2>
          <p class="text-xl text-slate-700 mb-8 leading-relaxed italic text-slate-600">The industry gold standard for men. A timeless design combined with modern moisture-wicking technology for the everyday healthcare hero.</p>
          
          <div class="bg-slate-50 p-6 rounded-2xl mb-8 border border-slate-100 shadow-sm">
            <h4 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-3 italic">Professional Fabric Specs</h4>
            <p class="text-lg font-bold text-primary italic">Polyester / Spandex Performance Blend</p>
            <p class="text-sm text-slate-500 mt-2 italic">Weight: 180GSM | Style: Traditional V-Neck | Features: Easy Care, Wrinkle-Resistant</p>
          </div>
          
          <p class="font-bold text-slate-900 border-r-4 lg:border-r-0 lg:border-l-4 border-primary pr-4 lg:pr-0 lg:pl-4 italic text-primary">Best for: General Nursing, Dental Clinics, and Medical Teams.</p>
        </div>
      </div>

      <!-- Professional Series (Male Forest Green) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block px-4 py-1 bg-emerald-100 text-emerald-600 font-bold rounded-full text-xs mb-4 uppercase tracking-widest italic text-emerald-600">Professional Series</div>
          <h2 class="text-4xl font-black mb-6 italic text-slate-900 leading-tight">Classic Forest Green<br/>Professional Scrub Set</h2>
          <p class="text-xl text-slate-700 mb-8 leading-relaxed italic text-slate-600">A sophisticated color for a sophisticated professional. Our Forest Green series provides an authoritative look with the comfort required for 12+ hour shifts.</p>
          
          <div class="bg-slate-50 p-6 rounded-2xl mb-8 border border-slate-100 shadow-sm">
            <h4 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-3 italic">Professional Fabric Specs</h4>
            <p class="text-lg font-bold text-emerald-600 italic">High-Performance Poly-Core Blend</p>
            <p class="text-sm text-slate-500 mt-2 italic">Weight: 185GSM | Style: Classic Professional Fit | Features: Color-Fast, Anti-Pilling</p>
          </div>
          
          <p class="font-bold text-slate-900 border-l-4 border-emerald-600 pl-4 italic text-emerald-900">Designed for: Hospital Staff and Specialized Medical Units.</p>
        </div>
        <div class="aspect-[4/5] rounded-[3rem] overflow-hidden shadow-2xl relative">
          <img src="https://sc02.alicdn.com/kf/A469cfe1d629d476fb6d7c0231f37de3aT.png" alt="Forest Green Scrub Set Male" class="w-full h-full object-cover" />
          <div class="absolute bottom-6 left-6 bg-white/90 backdrop-blur px-4 py-2 rounded-xl text-xs font-bold uppercase italic text-emerald-600 shadow-sm">Forest Green Collection</div>
        </div>
      </div>

      <!-- One-Piece Jumpsuit (Female Charcoal) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 aspect-[4/5] rounded-[3rem] overflow-hidden shadow-2xl relative">
          <img src="https://sc02.alicdn.com/kf/Afa9b2c28a97f47c5892c840728a7e217Y.png" alt="Charcoal Grey Jumpsuit Scrub Female" class="w-full h-full object-cover" />
          <div class="absolute bottom-6 right-6 bg-white/90 backdrop-blur px-4 py-2 rounded-xl text-xs font-bold uppercase italic text-indigo-600 shadow-sm">One-Piece Fashion</div>
        </div>
        <div class="order-1 lg:order-2 text-right lg:text-left">
          <div class="inline-block px-4 py-1 bg-indigo-100 text-indigo-600 font-bold rounded-full text-xs mb-4 uppercase tracking-widest italic text-indigo-600">Jumpsuit Series</div>
          <h2 class="text-4xl font-black mb-6 italic text-slate-900 leading-tight">Signature Charcoal Grey<br/>Medical Scrub Jumpsuit</h2>
          <p class="text-xl text-slate-700 mb-8 leading-relaxed italic text-slate-600">Elevate your wardobe with our signature one-piece jumpsuit. Combining high-end professional elegance with hospital-grade durability. No more tuck-in required.</p>
          
          <div class="bg-slate-50 p-6 rounded-2xl mb-8 border border-slate-100 shadow-sm">
            <h4 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-3 italic">Professional Fabric Specs</h4>
            <p class="text-lg font-bold text-indigo-600 italic">Signature Poly-Flex Rayon Blend</p>
            <p class="text-sm text-slate-500 mt-2 italic">Weight: 195GSM | Style: Cinched Waist Jumpsuit | Features: Concealed Zip, Multiple Pockets</p>
          </div>
          
          <p class="font-bold text-slate-900 border-r-4 lg:border-r-0 lg:border-l-4 border-indigo-600 pr-4 lg:pr-0 lg:pl-4 italic text-indigo-900">Ideal for: Aesthetic Clinics, Pediatrics, and High-End Healthcare Spas.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>