---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    title: "The Science of Comfort: Why 72/21/7 is the Gold Standard",
    excerpt: "Discover why the 72% Polyester, 21% Rayon, and 7% Spandex blend is the definitive choice for premium medical scrubs.",
    date: "April 10, 2026",
    image: "https://sc02.alicdn.com/kf/A0064eeab34cc43ffaad5a0739e62beafC.png",
    slug: "why-72-21-7-is-best",
    category: "Fabric Tech"
  },
  {
    title: "Smart Factories: AI Transformation in Medical Scrub Production",
    excerpt: "How Yilong is using AI to slash lead times and solve the 'Slow Response' industry pain point in 2025.",
    date: "December 15, 2025",
    image: "https://sc02.alicdn.com/kf/A6c9a8add0496444fba0d8ebd8fc6c61cH.png",
    slug: "future-of-ai-in-manufacturing",
    category: "Innovation"
  },
  {
    title: "Smart Procurement: Solving the High MOQ Barrier for Clinics",
    excerpt: "Why our 10-set MOQ is revolutionizing how private practices and startups source their medical uniforms.",
    date: "June 20, 2025",
    image: "https://sc02.alicdn.com/kf/A204336e23ae14b80aa021d32eb19fa5fn.png",
    slug: "procurement-for-small-clinics",
    category: "Sourcing"
  },
  {
    title: "Hospital Color Trends 2024: Beyond the Basic Blue",
    excerpt: "The rise of Sage Green and Charcoal: Exploring the psychology behind the modern healthcare palette.",
    date: "June 15, 2024",
    image: "https://sc02.alicdn.com/kf/A5def14b1fe684b58819971fb7f22d9b8y.png",
    slug: "hospital-color-trends-2024",
    category: "Trends"
  },
  {
    title: "Global Guide: Sourcing Medical Apparel from China",
    excerpt: "A 5-point vetting checklist to avoid traders and find a true 20-year manufacturing legacy partner.",
    date: "December 12, 2021",
    image: "https://sc02.alicdn.com/kf/Aec95977cfa6a4d1baef4aae1c2b42c5co.png",
    slug: "sourcing-medical-apparel-guide",
    category: "Sourcing"
  },
  {
    title: "Resilience: Managing the Supply Chain Crisis of 2020",
    excerpt: "Lessons in vertical integration and local sourcing during the most challenging year in manufacturing history.",
    date: "June 15, 2020",
    image: "https://sc02.alicdn.com/kf/A23446d76a9154c50bbffb0ad42bac9a7a.png",
    slug: "managing-supply-chain-crisis-2020",
    category: "History"
  }
];
---
<Layout 
  title="Industry Insights & Expert Blog | Yilong Scrubs" 
  description="Explore deep-dive articles on fabric science, sourcing strategies, and manufacturing innovation from the Yilong Team since 2020."
  keywords="medical scrubs blog, nursing uniform trends, fabric technology insights, healthcare apparel manufacturing"
>
  <div class="container mx-auto px-4 py-16 md:py-32">
    <header class="max-w-4xl mx-auto text-center mb-24 md:mb-32">
      <div class="inline-block px-6 py-2 bg-primary/5 text-primary font-black uppercase tracking-[0.3em] text-xs rounded-full mb-8 italic">Expertise Documented</div>
      <h1 class="text-5xl md:text-8xl font-black italic text-slate-900 leading-[0.9] tracking-tighter mb-10">Industry<br/>Insights.</h1>
      <p class="text-xl md:text-2xl text-slate-400 italic leading-relaxed max-w-2xl mx-auto">Solving medical apparel pain points through 20 years of manufacturing wisdom and technological innovation.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 max-w-7xl mx-auto">
      {posts.map((post, index) => (
        <article class={`group relative ${index === 0 ? 'md:col-span-2' : ''}`}>
          <a href={`/blog/${post.slug}`} class="block overflow-hidden rounded-[3rem] shadow-2xl relative aspect-video md:aspect-auto md:h-[600px]">
            <img 
              src={post.image} 
              alt={post.title} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent opacity-90"></div>
            
            <div class="absolute inset-0 p-8 md:p-16 flex flex-col justify-end">
              <div class="flex items-center gap-4 mb-6">
                <span class="px-4 py-1 bg-secondary text-white font-black text-[10px] uppercase tracking-widest rounded-full italic">{post.category}</span>
                <span class="text-white/60 font-bold text-xs italic uppercase tracking-widest">{post.date}</span>
              </div>
              <h2 class={`font-black italic text-white leading-tight tracking-tighter mb-6 group-hover:underline decoration-secondary decoration-4 underline-offset-8 transition-all ${index === 0 ? 'text-4xl md:text-7xl' : 'text-3xl md:text-5xl'}`}>
                {post.title}
              </h2>
              <p class="text-lg md:text-xl text-white/70 italic line-clamp-2 max-w-2xl group-hover:text-white transition-colors">
                {post.excerpt}
              </p>
              <div class="mt-8 flex items-center gap-4 text-white font-black uppercase text-xs tracking-[0.2em] italic">
                Read Deep Dive <span class="w-12 h-px bg-white group-hover:w-20 transition-all"></span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Historical Archive Section -->
    <div class="mt-40 pt-20 border-t border-slate-100 max-w-7xl mx-auto">
      <h3 class="text-3xl font-black italic text-slate-900 mb-12">Historical Archive (2020-2023)</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-8 bg-slate-50 rounded-3xl border border-slate-100 italic">
          <p class="text-xs text-slate-400 font-bold uppercase mb-2">Dec 2023</p>
          <h4 class="font-black text-lg mb-2">Lead Time Optimization</h4>
          <p class="text-sm text-slate-500 mb-4">How we slashed production times by 30%.</p>
          <a href="#" class="text-primary font-bold text-[10px] uppercase tracking-widest">Locked Content</a>
        </div>
        <div class="p-8 bg-slate-50 rounded-3xl border border-slate-100 italic">
          <p class="text-xs text-slate-400 font-bold uppercase mb-2">June 2022</p>
          <h4 class="font-black text-lg mb-2">Sustainable Dyeing</h4>
          <p class="text-sm text-slate-500 mb-4">The shift toward water-less reactive dyes.</p>
          <a href="#" class="text-primary font-bold text-[10px] uppercase tracking-widest">Locked Content</a>
        </div>
        <div class="p-8 bg-slate-50 rounded-3xl border border-slate-100 italic">
          <p class="text-xs text-slate-400 font-bold uppercase mb-2">Dec 2020</p>
          <h4 class="font-black text-lg mb-2">Antimicrobial Fabrics</h4>
          <p class="text-sm text-slate-500 mb-4">Silver-ion treatments in hospital settings.</p>
          <a href="#" class="text-primary font-bold text-[10px] uppercase tracking-widest">Locked Content</a>
        </div>
      </div>
    </div>
  </div>
</Layout>