---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Connect with Yilong | Request a Wholesale Quote" 
  description="Ready to start your medical scrubs project? Fill out our advanced inquiry form for a custom quote on OEM/ODM manufacturing and RTS collections."
  keywords="contact scrub manufacturer, custom scrub quote, wholesale medical apparel inquiry, scrub factory contact"
>
  <div class="container mx-auto px-4 py-16 md:py-24 text-center">
    <h1 class="text-4xl md:text-6xl font-black mb-8 md:mb-12 italic text-slate-900 leading-tight">Connect with Yilong</h1>
    <p class="text-xl text-slate-500 mb-16 italic max-w-2xl mx-auto">Providing precise manufacturing solutions for healthcare brands worldwide.</p>

    <div class="max-w-4xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 text-left">
      <!-- Contact Info -->
      <div class="space-y-12">
        <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100">
          <h3 class="text-2xl font-black mb-6 italic text-primary">Direct Contact</h3>
          <div class="space-y-6">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">WhatsApp</span>
              <a href="https://wa.me/8615556105350" class="text-xl font-black hover:text-primary transition italic underline decoration-secondary">+86 155 5610 5350</a>
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Email</span>
              <a href="mailto:marvin@sibaizhi.com" class="text-xl font-black hover:text-primary transition italic underline decoration-secondary">marvin@sibaizhi.com</a>
            </div>
          </div>
        </div>

        <div class="p-8 bg-primary text-white rounded-[2.5rem] shadow-xl italic">
          <h4 class="font-black text-xl mb-4 text-secondary">Why Yilong Team?</h4>
          <p class="opacity-90 leading-relaxed">20 years of expertise, 72/21/7 gold-ratio fabric, and 10-set MOQs. We are your dedicated partner in medical apparel excellence.</p>
        </div>
      </div>

      <!-- Advanced Lead-Gen Form (Learned from Bestex) -->
      <div class="bg-white p-8 md:p-12 rounded-[3rem] shadow-2xl border border-slate-50">
        <form class="space-y-6 italic">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-bold uppercase text-slate-400 mb-2">First Name</label>
              <input type="text" class="w-full bg-slate-50 border-none rounded-xl p-4 focus:ring-2 focus:ring-primary" placeholder="John" />
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase text-slate-400 mb-2">Last Name</label>
              <input type="text" class="w-full bg-slate-50 border-none rounded-xl p-4 focus:ring-2 focus:ring-primary" placeholder="Doe" />
            </div>
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase text-slate-400 mb-2">Work Email</label>
            <input type="email" class="w-full bg-slate-50 border-none rounded-xl p-4 focus:ring-2 focus:ring-primary" placeholder="john@hospital.com" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-bold uppercase text-slate-400 mb-2">Target MOQ</label>
              <select class="w-full bg-slate-50 border-none rounded-xl p-4 focus:ring-2 focus:ring-primary">
                <option>10-50 Sets</option>
                <option>50-200 Sets</option>
                <option>200-1000 Sets</option>
                <option>1000+ Sets</option>
              </select>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase text-slate-400 mb-2">Selling Platform</label>
              <select class="w-full bg-slate-50 border-none rounded-xl p-4 focus:ring-2 focus:ring-primary">
                <option>Amazon/E-commerce</option>
                <option>Private Clinic</option>
                <option>Hospital Wholesale</option>
                <option>Retail Store</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase text-slate-400 mb-2">Message & Specs</label>
            <textarea class="w-full bg-slate-50 border-none rounded-xl p-4 h-32 focus:ring-2 focus:ring-primary" placeholder="Describe your custom project or RTS needs..."></textarea>
          </div>
          <button type="button" class="w-full bg-primary text-white font-black py-5 rounded-2xl hover:bg-blue-800 transition shadow-xl uppercase tracking-widest text-lg">Send Inquiry</button>
        </form>
      </div>
    </div>
  </div>
</Layout>