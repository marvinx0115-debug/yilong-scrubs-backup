---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Connect with Yilong | Wholesale & Custom Scrub Inquiries" 
  description="Contact Yilong Scrubs for wholesale medical uniforms, OEM/ODM inquiries, and custom scrub manufacturing. Get a fast response via WhatsApp or Email."
  keywords="contact scrub manufacturer, custom scrub quote, wholesale medical apparel inquiry"
>
  <div class="container mx-auto px-4 py-16 md:py-24 text-center">
    <h1 class="text-3xl md:text-5xl font-black mb-8 md:mb-12 italic text-slate-900 leading-tight">Connect with Yilong</h1>
    <div class="max-w-2xl mx-auto p-8 md:p-12 bg-white rounded-[2rem] md:rounded-[3rem] shadow-xl border border-slate-50">
      <p class="text-lg md:text-xl mb-8 md:mb-10 font-bold italic text-primary">Ready to start your custom nursing scrubs project?</p>
      <div class="space-y-6">
        <div class="font-bold flex flex-col md:flex-row items-center justify-center gap-2 md:gap-3">
          <span class="text-slate-400 text-xs uppercase tracking-widest">WhatsApp:</span> 
          <a href="https://wa.me/8615556105350" class="text-lg md:text-xl hover:text-primary transition underline decoration-2 underline-offset-4">+8615556105350</a>
        </div>
        <div class="font-bold flex flex-col md:flex-row items-center justify-center gap-2 md:gap-3 mb-8 md:mb-12">
          <span class="text-slate-400 text-xs uppercase tracking-widest">Email:</span> 
          <a href="mailto:marvin@sibaizhi.com" class="text-lg md:text-xl hover:text-primary transition underline decoration-2 underline-offset-4">marvin@sibaizhi.com</a>
        </div>
      </div>
      <a href="https://wa.me/8615556105350" target="_blank" class="inline-block w-full sm:w-auto bg-primary text-white font-black py-5 px-10 md:px-12 rounded-2xl text-base md:text-lg uppercase tracking-widest hover:bg-blue-800 transition shadow-lg mt-4">Get a Fast Quote</a>
    </div>
  </div>
</Layout>