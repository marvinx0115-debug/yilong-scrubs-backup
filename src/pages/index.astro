---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Yilong Scrubs | 20-Year Medical Scrubs Manufacturer & Wholesale Supplier" 
  description="Premium nursing scrubs manufacturer since 2006. 100% focused on high-quality 4-way stretch hospital uniforms. Low MOQ & OEM/ODM services for global healthcare brands."
  keywords="medical scrubs manufacturer, nursing scrubs wholesale, hospital uniform factory, custom medical scrubs, 20 year garment factory"
>
  <section class="relative h-[85vh] md:h-[700px] flex items-center bg-primary text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://sc02.alicdn.com/kf/Aa8c317d768c143bf98a8a63a6a5de8f34.png" alt="Wholesale Medical Scrubs Manufacturer Team" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/80 to-transparent opacity-95"></div>
    </div>
    <div class="container mx-auto px-4 z-10 py-16 md:py-0">
      <div class="inline-block px-3 md:px-4 py-1 bg-secondary text-white font-bold rounded-full text-[10px] md:text-xs mb-4 md:mb-6 uppercase tracking-widest italic animate-pulse">Factory Direct Sourcing</div>
      <h1 class="text-3xl md:text-5xl lg:text-7xl font-extrabold mb-4 md:mb-6 leading-tight italic">20 Years of Precision.<br/><span class="text-secondary underline decoration-4 underline-offset-8">100% Focused</span> on Your Comfort.</h1>
      <p class="text-base md:text-lg lg:text-xl max-w-xl md:max-w-2xl mb-6 md:mb-10 text-slate-100 leading-relaxed">
        Yilong Scrubs: Discover professional-grade medical scrubs and nursing uniforms engineered for performance, durability, and a perfect fit. Crafted with OEKO-TEX® certified fabrics.
      </p>
      <div class="flex flex-col sm:flex-row flex-wrap gap-3 md:gap-4">
        <a href="/products" class="bg-secondary px-6 md:px-10 py-3 md:py-4 rounded-full font-bold text-sm md:text-lg hover:bg-emerald-600 transition shadow-lg text-center">Explore Collections</a>
        <a href="/catalog" class="bg-white text-primary px-6 md:px-10 py-3 md:py-4 rounded-full font-bold text-sm md:text-lg hover:bg-slate-100 transition shadow-lg text-center flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 md:h-5 w-4 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          View 2026 Catalog
        </a>
      </div>
    </div>
  </section>

  <!-- Data Counters Section -->
  <section class="py-8 md:py-12 bg-slate-900 text-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center">
        <div>
          <div class="text-3xl md:text-4xl lg:text-5xl font-black text-secondary mb-1 md:mb-2 italic">20+</div>
          <p class="text-[9px] md:text-[10px] text-slate-400 font-bold uppercase tracking-[0.15em] md:tracking-[0.2em]">Years of Expertise</p>
        </div>
        <div>
          <div class="text-3xl md:text-4xl lg:text-5xl font-black text-secondary mb-1 md:mb-2 italic">80+</div>
          <p class="text-[9px] md:text-[10px] text-slate-400 font-bold uppercase tracking-[0.15em] md:tracking-[0.2em]">Global Markets</p>
        </div>
        <div>
          <div class="text-3xl md:text-4xl lg:text-5xl font-black text-secondary mb-1 md:mb-2 italic">500k+</div>
          <p class="text-[9px] md:text-[10px] text-slate-400 font-bold uppercase tracking-[0.15em] md:tracking-[0.2em]">Monthly Capacity</p>
        </div>
        <div>
          <div class="text-3xl md:text-4xl lg:text-5xl font-black text-secondary mb-1 md:mb-2 italic">100%</div>
          <p class="text-[9px] md:text-[10px] text-slate-400 font-bold uppercase tracking-[0.15em] md:tracking-[0.2em]">Scrubs Specialist</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-4xl font-bold mb-3 md:mb-4 italic text-slate-900">Premium Nursing Scrubs Solutions</h2>
      <p class="text-slate-500 mb-10 md:mb-16 text-base md:text-lg italic">Building trust through quality and reliability for over two decades.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-10">
        <div class="p-6 md:p-10 border border-slate-100 rounded-3xl shadow-sm hover:shadow-xl transition-all">
          <h3 class="text-lg md:text-xl font-bold mb-3 md:mb-4 italic text-primary">20-Year Heritage</h3>
          <p class="text-slate-600 italic text-sm md:text-base">Two decades of specialized manufacturing experience in the global medical apparel market.</p>
        </div>
        <div class="p-6 md:p-10 border border-slate-100 rounded-3xl shadow-sm hover:shadow-xl transition-all">
          <h3 class="text-lg md:text-xl font-bold mb-3 md:mb-4 italic text-primary">100% Scrubs Focus</h3>
          <p class="text-slate-600 italic text-sm md:text-base">We don't just make uniforms; we specialize exclusively on hospital scrubs and nursing wear.</p>
        </div>
        <div class="p-6 md:p-10 border border-slate-100 rounded-3xl shadow-sm hover:shadow-xl transition-all">
          <h3 class="text-lg md:text-xl font-bold mb-3 md:mb-4 italic text-primary">Flexible Low MOQ</h3>
          <p class="text-slate-600 italic text-sm md:text-base">Starting from 10-50 sets, making professional custom nursing scrubs accessible for startups.</p>
        </div>
        <div class="p-6 md:p-10 border border-slate-100 rounded-3xl shadow-sm hover:shadow-xl transition-all">
          <h3 class="text-lg md:text-xl font-bold mb-3 md:mb-4 italic text-primary">Certified Safety</h3>
          <p class="text-slate-600 italic text-sm md:text-base">All nursing uniform fabrics are OEKO-TEX® Standard 100 certified for safety.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>