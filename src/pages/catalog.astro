---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="2026 Catalog | Yilong Scrubs" 
  description="View our complete 2026 product catalog featuring premium medical scrubs and nursing uniforms."
>
  <div class="container mx-auto px-4 py-16">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-8 gap-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-black italic text-slate-900">2026 Product Catalog</h1>
        <p class="text-slate-500 mt-2 italic">Premium medical scrubs and nursing uniforms collection</p>
      </div>
      <a href="/Yilong_Scrubs_Catalog_2026.pdf" download class="bg-primary text-white px-6 py-3 rounded-full font-bold text-sm hover:bg-blue-800 transition flex items-center gap-2 whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Download PDF
      </a>
    </div>
    
    <!-- PDF 预览 - 使用 Google Docs Viewer -->
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-100">
      <div class="w-full" style="height: 80vh; min-height: 600px;">
        <iframe 
          src="https://docs.google.com/gview?url=https://yilong-scrubs-backup.pages.dev/Yilong_Scrubs_Catalog_2026.pdf&embedded=true" 
          class="w-full h-full border-0"
          title="Yilong Scrubs 2026 Catalog"
          loading="lazy"
        ></iframe>
      </div>
    </div>
    
    <!-- 加载提示 -->
    <p class="text-center text-slate-500 mt-6 text-sm italic">
      Loading PDF... If it doesn't load, please <a href="/Yilong_Scrubs_Catalog_2026.pdf" download class="text-primary underline hover:text-blue-800">download it here</a>
    </p>
  </div>
</Layout>