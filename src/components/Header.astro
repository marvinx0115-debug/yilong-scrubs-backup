---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/fabric-tech', label: 'Fabric & Tech' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About Us' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="container mx-auto px-4 py-4 flex justify-between items-center">
    <a href="/" class="text-xl md:text-2xl font-bold text-primary italic">Yilong Scrubs</a>
    
    <!-- Desktop Nav -->
    <nav class="hidden md:flex space-x-4 lg:space-x-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-slate-600 hover:text-primary font-bold uppercase text-[10px] lg:text-xs tracking-widest transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile Menu Button -->
    <button id="menu-toggle" class="md:hidden p-2 text-slate-600 hover:text-primary focus:outline-none border border-slate-100 rounded-lg">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>

  <!-- Mobile Nav Overlay -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 absolute w-full left-0 shadow-2xl z-50">
    <nav class="flex flex-col p-6 space-y-4">
      {navLinks.map(link => (
        <a href={link.href} class="text-slate-600 hover:text-primary font-bold uppercase text-sm tracking-widest py-3 px-4 rounded-xl hover:bg-slate-50 transition-all border-b border-slate-50 last:border-none">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  // Use a more robust initialization
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = mobileMenu.classList.contains('hidden');
        if (isHidden) {
          mobileMenu.classList.remove('hidden');
          menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // Close icon
        } else {
          mobileMenu.classList.add('hidden');
          menuIcon.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7'); // Hamburger icon
        }
      });

      // Close menu when clicking outside
      document.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuIcon.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
      });
    }
  });
</script>
